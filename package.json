{
	"name": "introduction.exe",
	"private": true,
	"version": "0.0.0",
	"author": "AptS:1547 <apts-1547@esaps.net>",
	"description": "A personal introduction website built with React, Vite, and Tailwind CSS.",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsgo -b && vite build",
		"check": "tsgo -b && biome check .",
		"check:fix": "biome check --write .",
		"format": "biome format --write .",
		"preview": "vite preview",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.3.1",
		"framer-motion": "^12.40.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-icons": "^5.6.0",
		"react-router": "^7.17.0",
		"tailwindcss": "^4.3.1",
		"@vitest/coverage-v8": "^4.1.8",
		"vitest": "^4.1.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.9.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260612.1",
		"@vitejs/plugin-react": "^6.0.2",
		"globals": "^17.6.0",
		"jsdom": "^29.1.1",
		"typescript-eslint": "^8.61.0",
		"vite": "^8.0.16"
	}
}
